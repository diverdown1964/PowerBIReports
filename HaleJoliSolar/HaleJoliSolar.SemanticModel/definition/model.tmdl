model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-CA
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Solar Telemetry","Dates","Time"]

annotation PBI_ProTooling = ["MCP-PBIModeling","TMDLView_Desktop","DevMode"]

ref table 'Solar Telemetry'
ref table Dates
ref table Time
ref table Parameters
ref table 'Cost Conversion'

ref cultureInfo en-US

