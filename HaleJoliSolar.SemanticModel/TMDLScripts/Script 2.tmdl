createOrReplace

	table 'Cost Conversion'
		lineageTag: a351f9f8-19c2-43d2-8a41-fa06e414d09b

		/// Converts kWh measures to cost using Power Rate parameter
		calculationGroup
			precedence: 10

			/// Original value in kWh (no conversion)
			calculationItem kWh = SELECTEDMEASURE()

			/// Multiply kWh by Power Rate to get cost
			calculationItem 'Amount ($)' = SELECTEDMEASURE() * [Power Rate]

				formatStringDefinition = "$#,##0.00"

			/// Average daily cost
			calculationItem 'Daily Avg Amount ($)' = (SELECTEDMEASURE() / [Days in Period]) * [Power Rate]

				formatStringDefinition = "$#,##0.00"

		column 'Cost Conversion'
			dataType: string
			lineageTag: db26da4d-9391-4b30-861f-08b09f066abb

		partition 'Partition_Cost Conversion' = calculationGroup

